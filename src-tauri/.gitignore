# Rust build output (standalone crate => its own target/).
/target

# Tauri v2 codegen output (generated by tauri-build at compile time).
/gen

# Generated app icons (run `cargo tauri icon <logo.png>` to (re)create).
/icons/*.png
/icons/*.icns
/icons/*.ico

# The DeepCW AI CW model (AGPL-3.0, (c) e04) is staged here for bundling but NOT
# committed — see resources/deepcw/README.md for provenance + how to fetch it.
/resources/deepcw/*.onnx
/resources/deepcw/*.onnx.json
